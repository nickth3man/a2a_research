{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend (unified)",
      "type": "process",
      "command": "uv run uvicorn entrypoints.api:app --host 0.0.0.0 --port 8000 --reload",
      "description": "FastAPI gateway + all 12 agents mounted at /agents/* on port 8000"
    },
    {
      "name": "Frontend",
      "type": "process",
      "command": "pnpm run dev",
      "cwd": "apps/web",
      "description": "Vite dev server (default port 5173)"
    },
    {
      "name": "Backend agents (standalone)",
      "type": "process",
      "command": "uv run python -m entrypoints.launcher",
      "description": "Run planner/searcher/reader/fact-checker/synthesizer on separate ports"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["Backend (unified)", "Frontend"],
      "description": "Start backend + frontend together"
    }
  ]
}
