# ── LLM (OpenRouter-compatible API) ─────────────────────────────────────
# Traffic is routed through an OpenAI-compatible base URL (default: OpenRouter).
# Legacy: LLM_PROVIDER=openrouter (ignored if present).
#
# Model id examples (OpenRouter): openrouter/elephant-alpha (default),
#   openai/gpt-4o, anthropic/claude-3.5-sonnet, google/gemini-2.5-pro-preview
LLM_MODEL=openrouter/elephant-alpha

# Base URL for OpenAI-compatible APIs (default: OpenRouter).
# For a local Ollama OpenAI shim use: http://localhost:11434/v1
LLM_BASE_URL=https://openrouter.ai/api/v1

# API key for the base URL above (OpenRouter: sk-or-... at https://openrouter.ai/keys).
LLM_API_KEY=sk-or-...

# ── A2A HTTP services ─────────────────────────────────────────────────────
PLANNER_PORT=10001
SEARCHER_PORT=10002
READER_PORT=10003
FACT_CHECKER_PORT=10004
SYNTHESIZER_PORT=10005

PLANNER_URL=http://localhost:10001
SEARCHER_URL=http://localhost:10002
READER_URL=http://localhost:10003
FACT_CHECKER_URL=http://localhost:10004
SYNTHESIZER_URL=http://localhost:10005

# ── Web Search ────────────────────────────────────────────────────────
# Tavily search API key (required). Free tier is 1000 credits/month.
# Get one at https://tavily.com/
TAVILY_API_KEY=tvly-...

# Brave Search API key (required). Subscribe at https://api-dashboard.search.brave.com/
BRAVE_API_KEY=...

# Per-provider fetch cap for parallel Tavily + Brave + DuckDuckGo; merged hits are
# capped separately (see tools.search.web_search).
SEARCH_MAX_RESULTS=5

# Maximum number of tool-calling steps for the smolagents Searcher agent.
# Each step = one LLM call + tool invocation (e.g. web_search).
# Increase if the agent exhausts its budget before returning structured results.
SEARCHER_MAX_STEPS=5

# ── Research Loop ─────────────────────────────────────────────────────
# Maximum number of fact-check rounds the FactChecker will run before
# giving up on NEEDS_MORE_EVIDENCE claims and handing off to Synthesizer.
RESEARCH_MAX_ROUNDS=5

# ── Application ──────────────────────────────────────────────────────
# Threshold for console and all logs/*.log files (see app_logging module for names).
# DEBUG keeps full detail in everything.log and split topic files under logs/.
LOG_LEVEL=DEBUG

# Port the Mesop web UI listens on. Open http://localhost:32123 to use the UI.
MESOP_PORT=32123

# Maximum workflow runtime in seconds before returning a partial timed-out session.
WORKFLOW_TIMEOUT=180

# Mesop UI state server-side (token + memory cache) instead of round-tripping
# full state blobs on every POST. Can reduce dev-console errors after hot reload.
# Values: none | memory | file | …
# MESOP_STATE_SESSION_BACKEND=memory

# ── Workflow Configuration (WF_ prefix) ───────────────────────────────
# All workflow config keys use the WF_ prefix.
# Example: WF_BUDGET_MAX_ROUNDS=5

# Budget limits
WF_BUDGET_MAX_ROUNDS=5
WF_BUDGET_MAX_TOKENS=200000
WF_BUDGET_MAX_WALL_SECONDS=180
WF_BUDGET_MAX_HTTP_CALLS=50
WF_BUDGET_MIN_MARGINAL_EVIDENCE=2
WF_BUDGET_MAX_CRITIC_REVISION_LOOPS=2

# Search configuration
WF_SEARCH_PROVIDERS=["tavily","brave","ddg"]
WF_SEARCH_PARALLEL=true
WF_SEARCH_MAX_RESULTS_PER_PROVIDER=5

# Ranking
WF_RANKING_ENABLED=true
WF_RANKING_FETCH_BUDGET=8
WF_RANKING_DIVERSITY_PENALTY=0.3
WF_RANKING_FRESHNESS_WEIGHT_DEFAULT=0.2

# Evidence processing
WF_EVIDENCE_DEDUPLICATION=true
WF_EVIDENCE_CHUNK_SIZE=1000
WF_EVIDENCE_CHUNK_OVERLAP=200
WF_EVIDENCE_SOURCE_INDEPENDENCE=true

# Adversary stage
WF_ADVERSARY_ENABLED=true
WF_ADVERSARY_TRIGGER=on_tentative_supported
WF_ADVERSARY_INVERSION_QUERY_COUNT=3
WF_ADVERSARY_COUNTER_EXPERT_LOOKUP=true

# Verification
WF_VERIFICATION_CACHE_RESULTS=true
WF_VERIFICATION_CONFIDENCE_AUTO_ACCEPT_THRESHOLD=0.9
WF_VERIFICATION_SHORT_CIRCUIT_WHEN_ADVERSARY_HOLDS=true

# Synthesis
WF_SYNTHESIS_STREAMING=sse_via_coordinator
WF_SYNTHESIS_TENTATIVE_SNAPSHOT_STRATEGY=cheap_template_every_round_plus_full_on_exit

# Output
WF_OUTPUT_FORMATS=["markdown","json"]
WF_OUTPUT_CITATION_STYLE=hyperlinked_footnotes

# Checkpointing
WF_CHECKPOINTING_ENABLED=true
WF_CHECKPOINTING_STAGES=["plan","verify","adversary_gate","synthesize"]

# PII handling
WF_PII_QUERY_EGRESS=hash_with_session_key
WF_PII_EVIDENCE_INGEST=mask
WF_PII_CHECKPOINT_WRITE=mask
WF_PII_PRE_SYNTHESIS=mask

# Telemetry
WF_TELEMETRY_OPENTELEMETRY=true
WF_TELEMETRY_PROMETHEUS=true
WF_TELEMETRY_TRACE_LOG=true
WF_TELEMETRY_TRACE_IDS=["session_id","trace_id","span_id"]

# Cost attribution
WF_COST_ATTRIBUTION_ENABLED=true
WF_COST_ATTRIBUTION_TAGS=["session_id","claim_id","user_id"]

# A/B testing
WF_AB_TESTING_ENABLED=true
WF_AB_TESTING_SAMPLING=per_query_class_sticky
WF_AB_TESTING_WINNER_METRIC=weighted_composite
WF_AB_TESTING_WEIGHTS={"claim_recall":0.35,"citation_accuracy":0.35,"latency":0.15,"cost":0.15}
