# ── LLM Provider ──────────────────────────────────────────────────────
# Which LLM vendor to use. Supported: openrouter | openai | anthropic |
# google | ollama.
# OpenRouter is the default: it gives you access to 300+ models from a
# single API key and base URL, including free options.
LLM_PROVIDER=openrouter

# Model name — provider-specific. Examples:
#   openrouter: openrouter/elephant-alpha (free 100B, default)
#               openai/gpt-4o, anthropic/claude-3.5-sonnet,
#               google/gemini-2.5-pro-preview, openrouter/free
#   openai:     gpt-4o-mini, gpt-4o
#   anthropic:  claude-sonnet-4-20250514
#   google:     gemini-2.0-flash
#   ollama:     llama3.2, mistral, qwen2.5
LLM_MODEL=openrouter/elephant-alpha

# Base URL for OpenAI-compatible APIs.
# OpenRouter: https://openrouter.ai/api/v1  (default)
# Ollama (local): http://localhost:11434/v1
# Leave blank when using native openai / anthropic / google providers.
LLM_BASE_URL=https://openrouter.ai/api/v1

# API key for your chosen LLM_PROVIDER.
# OpenRouter keys start with sk-or-... — get one at https://openrouter.ai/keys
# Not required for Ollama (set LLM_PROVIDER=ollama, clear LLM_BASE_URL).
LLM_API_KEY=sk-or-...

# ── Web Search ────────────────────────────────────────────────────────
# Tavily search API key. Free tier is 1000 credits/month.
# Get one at https://tavily.com/. Leave blank to rely on DuckDuckGo only;
# the Searcher agent will degrade gracefully.
TAVILY_API_KEY=

# Per-provider result cap for the parallel Tavily + DuckDuckGo search.
# Each provider returns up to this many hits, then results are merged
# and deduplicated by URL.
SEARCH_MAX_RESULTS=5

# ── Research Loop ─────────────────────────────────────────────────────
# Maximum number of fact-check rounds the FactChecker will run before
# giving up on NEEDS_MORE_EVIDENCE claims and handing off to Synthesizer.
RESEARCH_MAX_ROUNDS=3

# ── Application ──────────────────────────────────────────────────────
# Logging verbosity. Use DEBUG for verbose agent logs, INFO for normal,
# WARNING for warnings only, ERROR to suppress most output.
LOG_LEVEL=INFO

# Port the Mesop web UI listens on. Open http://localhost:32123 to use the UI.
MESOP_PORT=32123

# Maximum workflow runtime in seconds before returning a partial timed-out session.
WORKFLOW_TIMEOUT=180

# Optional: store Mesop UI state server-side (token + memory cache) instead of
# round-tripping full state blobs on every POST. Can reduce dev-console errors
# like “Number of diffs … doesn’t equal … states” after hot reload when the
# client still holds an older state shape. Values: none | memory | file | …
# MESOP_STATE_SESSION_BACKEND=memory
