# ── LLM Provider ──────────────────────────────────────────────────────
# Which LLM vendor to use. All providers are configured via their
# respective API key / base URL below. Supported: openai | anthropic |
# google | ollama.
LLM_PROVIDER=openai

# Model name — provider-specific. Examples:
#   openai:    gpt-4o-mini, gpt-4o, gpt-4o-mini
#   anthropic: claude-sonnet-4-20250514, claude-3-5-sonnet-20250620
#   google:    gemini-2.0-flash, gemini-1.5-flash
#   ollama:    llama3.2, mistral, qwen2.5
LLM_MODEL=gpt-4o-mini

# Base URL for OpenAI-compatible APIs. Leave blank to use the provider's
# default endpoint. Example for Ollama (local): http://localhost:11434/v1
LLM_BASE_URL=

# API key for your chosen LLM_PROVIDER. Get from the provider's dashboard.
# Not required for Ollama (set LLM_PROVIDER=ollama and use LLM_BASE_URL).
LLM_API_KEY=sk-...

# ── Embeddings ────────────────────────────────────────────────────────
# Model for embedding query and corpus chunks during retrieval.
# Recommended: text-embedding-3-small (good quality, low cost) or
# text-embedding-ada-002 (lower quality) for OpenAI.
EMBEDDING_MODEL=text-embedding-3-small

# Embedding provider. Can differ from LLM_PROVIDER.
# Supported: openai | ollama
EMBEDDING_PROVIDER=openai

# Separate base URL for embeddings, e.g. a local Ollama instance.
# Blank means: use LLM_BASE_URL (or the provider default if that's also blank).
EMBEDDING_BASE_URL=

# API key for embedding provider. If blank, falls back to LLM_API_KEY.
# Not needed for Ollama embeddings (leave blank).
EMBEDDING_API_KEY=

# ── ChromaDB (Vector Store) ─────────────────────────────────────────────
# Directory for persistent ChromaDB storage. Created automatically;
# should be gitignored (already is in .gitignore).
CHROMA_PERSIST_DIR=data/chroma

# ChromaDB collection name. If it doesn't exist it is created on first ingest.
CHROMA_COLLECTION=a2a_research

# ── Document Chunking ───────────────────────────────────────────────────
# Target size for text chunks when ingesting data/corpus/*.md files.
# Chunks are split at sentence boundaries so actual size varies slightly.
CHUNK_SIZE=512

# Character overlap between adjacent chunks. Higher overlap helps keep
# context across chunk boundaries. Should be < CHUNK_SIZE.
CHUNK_OVERLAP=64

# ── Application ──────────────────────────────────────────────────────
# Logging verbosity. Use DEBUG for verbose agent logs, INFO for normal,
# WARNING for warnings only, ERROR to suppress most output.
LOG_LEVEL=INFO

# Port the Mesop web UI listens on. Open http://localhost:32123 to use the UI.
MESOP_PORT=32123