# ── LLM Provider ──────────────────────────────────────────────────────
# Which LLM vendor to use. Supported: openrouter | openai | anthropic |
# google | ollama.
# OpenRouter is the default: it gives you access to 300+ models from a
# single API key and base URL, including free options.
LLM_PROVIDER=openrouter

# Model name — provider-specific. Examples:
#   openrouter: openrouter/elephant-alpha (free 100B, default)
#               openai/gpt-4o, anthropic/claude-3.5-sonnet,
#               google/gemini-2.5-pro-preview, openrouter/free
#   openai:     gpt-4o-mini, gpt-4o
#   anthropic:  claude-sonnet-4-20250514
#   google:     gemini-2.0-flash
#   ollama:     llama3.2, mistral, qwen2.5
LLM_MODEL=openrouter/elephant-alpha

# Base URL for OpenAI-compatible APIs.
# OpenRouter: https://openrouter.ai/api/v1  (default)
# Ollama (local): http://localhost:11434/v1
# Leave blank when using native openai / anthropic / google providers.
LLM_BASE_URL=https://openrouter.ai/api/v1

# API key for your chosen LLM_PROVIDER.
# OpenRouter keys start with sk-or-... — get one at https://openrouter.ai/keys
# Not required for Ollama (set LLM_PROVIDER=ollama, clear LLM_BASE_URL).
LLM_API_KEY=sk-or-...

# ── Embeddings ────────────────────────────────────────────────────────
# Embedding provider. Can differ from LLM_PROVIDER.
# Supported: openrouter | openai | ollama
# OpenRouter exposes 10+ embedding models via a single API key.
EMBEDDING_PROVIDER=openrouter

# Embedding model name. Examples:
#   openrouter: perplexity/pplx-embed-v1-4b (2560 dims, 32K ctx, default)
#               perplexity/pplx-embed-v1-0.6b (1024 dims, cheaper)
#               openai/text-embedding-3-small
#   openai:     text-embedding-3-small, text-embedding-ada-002
#   ollama:     nomic-embed-text, mxbai-embed-large
EMBEDDING_MODEL=perplexity/pplx-embed-v1-4b

# Separate base URL for embeddings.
# Leave blank to inherit LLM_BASE_URL (correct for OpenRouter: both chat
# and embeddings live at https://openrouter.ai/api/v1).
EMBEDDING_BASE_URL=

# API key for embedding provider.
# Leave blank to inherit LLM_API_KEY (correct when using the same
# OpenRouter key for both chat and embeddings).
EMBEDDING_API_KEY=

# ── ChromaDB (Vector Store) ─────────────────────────────────────────────
# Directory for persistent ChromaDB storage. Created automatically;
# should be gitignored (already is in .gitignore).
CHROMA_PERSIST_DIR=data/chroma

# ChromaDB collection name. If it doesn't exist it is created on first ingest.
CHROMA_COLLECTION=a2a_research

# ── Document Chunking ───────────────────────────────────────────────────
# Target size for text chunks when ingesting data/corpus/*.md files.
# Chunks are split at sentence boundaries so actual size varies slightly.
CHUNK_SIZE=512

# Character overlap between adjacent chunks. Higher overlap helps keep
# context across chunk boundaries. Should be < CHUNK_SIZE.
CHUNK_OVERLAP=64

# ── Application ──────────────────────────────────────────────────────
# Logging verbosity. Use DEBUG for verbose agent logs, INFO for normal,
# WARNING for warnings only, ERROR to suppress most output.
LOG_LEVEL=INFO

# Port the Mesop web UI listens on. Open http://localhost:32123 to use the UI.
MESOP_PORT=32123

# Maximum workflow runtime in seconds before returning a partial timed-out session.
WORKFLOW_TIMEOUT=120

# Optional: store Mesop UI state server-side (token + memory cache) instead of
# round-tripping full state blobs on every POST. Can reduce dev-console errors
# like “Number of diffs … doesn’t equal … states” after hot reload when the
# client still holds an older state shape. Values: none | memory | file | …
# MESOP_STATE_SESSION_BACKEND=memory
